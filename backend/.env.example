# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CORS_ORIGIN=*

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/bondify

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ─── Redis (optional) ─────────────────────────────────────────────────────────
# Provide a Redis URL to enable:
#   • Socket.io Redis adapter  (multi-server / horizontal scaling)
#   • Distributed rate limiting (shared across all server instances)
#   • Discovery results caching (60-second TTL)
#
# Leave unset or empty to run in single-server mode without Redis.
#
# Local Redis:       redis://localhost:6379
# Redis with auth:   redis://:password@host:6379
# Redis TLS (prod):  rediss://user:password@host:6380
REDIS_URL=

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_bucket_name

# ─── AWS CloudFront CDN (Optional - for faster asset delivery) ───────────────
# Set this to your CloudFront distribution domain to serve assets via CDN
# Example: https://d1234567890.cloudfront.net
# Leave empty to use direct S3 URLs
AWS_CLOUDFRONT_DOMAIN=

# ─── OTP / Messaging ──────────────────────────────────────────────────────────
TERMII_API_KEY=your_termii_api_key
TERMII_BASE_URL=https://api.ng.termii.com
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# ─── Email (Resend / Nodemailer) ──────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@bondify.app

# ─── AI ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key

# ─── Payments (Paystack) ──────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=your_paystack_public_key
